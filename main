import asyncio
import logging
from datetime import datetime, timedelta
from aiogram import Bot, Dispatcher, types, F
from aiogram.filters import Command
from aiogram.utils.keyboard import InlineKeyboardBuilder
from apscheduler.schedulers.asyncio import AsyncIOScheduler
from flask import Flask
from threading import Thread

TOKEN = "ВАШ_ТОКЕН_БОТА"
bot = Bot(token=TOKEN)
dp = Dispatcher()
scheduler = AsyncIOScheduler()

# Веб-сервер для "оживления" сервера
app = Flask('')
@app.route('/')
def home(): return "Бот-напоминалка запущен!"

def run_web():
    app.run(host='0.0.0.0', port=7860)

async def send_reminder(chat_id, text, type):
    msg = "⏰ ПОРА: " if type == "main" else "⚠️ Через 5 минут: "
    await bot.send_message(chat_id, msg + text)

@dp.message(Command("start"))
async def start(message: types.Message):
    builder = InlineKeyboardBuilder()
    # Создаем кнопки с популярным временем для примера
    times = ["10:00", "14:00", "18:00", "21:00"]
    for t in times:
        builder.button(text=t, callback_data=f"time_{t}")
    builder.adjust(2)
    await message.answer("Выбери время для напоминания:", reply_markup=builder.as_markup())

@dp.callback_query(F.data.startswith("time_"))
async def set_time(callback: types.CallbackQuery):
    selected_time = callback.data.split("_")[1]
    chat_id = callback.message.chat.id
    
    # Расчет времени (упрощенно на текущий день)
    now = datetime.now()
    target = datetime.strptime(selected_time, "%H:%M").replace(year=now.year, month=now.month, day=now.day)
    
    # Планируем основное напоминание
    scheduler.add_job(send_reminder, 'date', run_date=target, args=[chat_id, "Твое важное дело!", "main"])
    
    # Планируем за 5 минут
    scheduler.add_job(send_reminder, 'date', run_date=target - timedelta(minutes=5), args=[chat_id, "Твое важное дело!", "warn"])
    
    await callback.message.edit_text(f"✅ Готово! Напомню в {selected_time}, и предупрежу за 5 минут до этого.")

async def main():
    Thread(target=run_web).start()
    scheduler.start()
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())
