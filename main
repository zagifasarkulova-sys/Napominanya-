import asyncio
import logging
from datetime import datetime, timedelta
from aiogram import Bot, Dispatcher, types, F
from aiogram.filters import Command
from aiogram.utils.keyboard import InlineKeyboardBuilder
from apscheduler.schedulers.asyncio import AsyncIOScheduler
from flask import Flask
from threading import Thread

# 1. Настройка
TOKEN = "ВАШ_ТОКЕН_ТУТ"
bot = Bot(token=TOKEN)
dp = Dispatcher()
scheduler = AsyncIOScheduler()

# 2. Веб-сервер для Анти-сна
app = Flask('')
@app.route('/')
def home(): return "Бот Напоминания активен!"

def run_web():
    app.run(host='0.0.0.0', port=7860)

# 3. Логика напоминаний
async def send_reminder(chat_id, text, is_warning=False):
    prefix = "⚠️ ПРЕДУПРЕЖДЕНИЕ: Через 5 минут — " if is_warning else "⏰ ПОРА: "
    await bot.send_message(chat_id, f"{prefix}{text}")

# 4. Обработка команд
@dp.message(Command("start"))
async def cmd_start(message: types.Message):
    builder = InlineKeyboardBuilder()
    builder.row(types.InlineKeyboardButton(text="⏰ Поставить напоминание", callback_data="add_rem"))
    await message.answer("Привет! Я помогу не забыть о важных делах.", reply_markup=builder.as_markup())

@dp.callback_query(F.data == "add_rem")
async def add_reminder_step1(callback: types.CallbackQuery):
    # Здесь можно сделать выбор времени кнопками, для примера поставим через 10 минут
    rem_time = datetime.now() + timedelta(minutes=10)
    task_text = "Пример задачи"
    chat_id = callback.message.chat.id

    # Напоминание за 5 минут
    scheduler.add_job(send_reminder, 'date', run_date=rem_time - timedelta(minutes=5), args=[chat_id, task_text, True])
    
    # Основное напоминание
    scheduler.add_job(send_reminder, 'date', run_date=rem_time, args=[chat_id, task_text, False])

    await callback.message.edit_text(f"✅ Напоминание создано на {rem_time.strftime('%H:%M')}\nЯ предупрежу тебя за 5 минут!")

async def main():
    Thread(target=run_web).start() # Запуск фляги
    scheduler.start()              # Запуск часов
    await dp.start_polling(bot)    # Запуск бота

if __name__ == "__main__":
    asyncio.run(main())
